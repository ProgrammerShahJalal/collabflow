NODE_ENV=development
PORT=4000

# Paste your MongoDB Atlas connection string here (must include /collabflow db name)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/collabflow

JWT_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

ALLOWED_ORIGINS=http://localhost:5173
UPLOAD_DEST=./uploads
MAX_FILE_SIZE_MB=10

DEMO_ADMIN_EMAIL=admin@collabflow.dev
DEMO_ADMIN_PASSWORD=Demo@1234
