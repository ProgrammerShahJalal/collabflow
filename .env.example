# Root reference — copy the relevant blocks into apps/api/.env and apps/web/.env

# ---- apps/api/.env ----
NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/collabflow
JWT_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ALLOWED_ORIGINS=http://localhost:5173
UPLOAD_DEST=./uploads
MAX_FILE_SIZE_MB=10
# Cloudinary — required for image/PDF attachment uploads.
# Either set the single connection string...
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# ...or the discrete variables (CLOUDINARY_URL takes precedence if present):
CLOUDINARY_CLOUD_NAME=<cloud_name>
CLOUDINARY_API_KEY=<api_key>
CLOUDINARY_API_SECRET=<api_secret>
DEMO_ADMIN_EMAIL=admin@collabflow.dev
DEMO_ADMIN_PASSWORD=Demo@1234

# ---- apps/web/.env ----
VITE_API_BASE_URL=http://localhost:4000/api/v1
VITE_WS_URL=http://localhost:4000
