# Root reference — copy the relevant blocks into apps/api/.env and apps/web/.env

# ---- apps/api/.env ----
NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/collabflow
JWT_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ALLOWED_ORIGINS=http://localhost:5173
UPLOAD_DEST=./uploads
MAX_FILE_SIZE_MB=10
DEMO_ADMIN_EMAIL=admin@collabflow.dev
DEMO_ADMIN_PASSWORD=Demo@1234

# ---- apps/web/.env ----
VITE_API_BASE_URL=http://localhost:4000/api/v1
VITE_WS_URL=http://localhost:4000
